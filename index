    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: Arial, sans-serif;
    }

    /* HERO */
    .hero {
      background-image: url("imagenes/actual-heropic.jpg");
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
      height: 100vh;
      width: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      color: white;
      position: relative;
    }

    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, 0.5);
    }

    .hero h1, .hero p {
      position: relative;
      z-index: 1;
    }

    .hero h1 {
      font-size: 3rem;
      margin-bottom: 10px;
    }

    .hero p {
      font-size: 1.2rem;
    }

    /* SECCIÓN DE INFO */
    .contenido {
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 40px;
      padding: 60px 40px;
      max-width: 1100px;
      margin: 0 auto;
      position: relative;
      z-index: 1;
    }

    .video {
      flex: 1;
      min-width: 300px;
    }

    .video iframe {
      width: 100%;
      height: 315px;
    }

    .texto {
      flex: 1;
    }

    .texto h2 {
      font-size: 2rem;
      margin-bottom: 20px;
    }

    .texto p {
      font-size: 1.1rem;
      line-height: 1.8;
      margin-bottom: 15px;
      color: #333;
    }

    /* DISCOGRAFÍA */
    .discografia {
      padding: 60px 40px;
      max-width: 1100px;
      margin: 0 auto;
    }

    .discografia h2 {
      font-size: 2rem;
      margin-bottom: 30px;
    }

    .albums {
      display: flex;
      flex-direction: row;
      gap: 20px;
      overflow-x: auto;
      padding-bottom: 20px;
    }

.albums {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: 20px;
}

    .album:hover {
      transform: scale(1.05);
    }

    .album img {
      width: 180px;
      height: 180px;
      object-fit: cover;
      border-radius: 8px;
    }
    .album p {
    margin-top: 8px;
    font-size: 1.1rem;
    font-family: "Bebas Neue", sans-serif;
    font-weight: bold;
    letter-spacing: 1px;
    }

/* MIEMBROS */
    .members {
    padding: 60px 40px;
    max-width: 1100px;
    margin: 0 auto;
    }

    .members h2 {
    font-size: 2rem;
    margin-bottom: 30px;
    }

    .member {
    display: flex;
    flex-direction: row;
    gap: 20px;
    overflow-x: auto;
    padding-bottom: 20px;
    }

    .member:hover {
    transform: scale(1.05);
    }


    .member {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 20px;
    }


    .member img {
    width: 180px;
    height: 250px;
    object-fit: cover;
    border-radius: 8px;
    }
    .member p {
    margin-top: 8px;
    font-size: 1.1rem;
    font-family: "Bebas Neue", sans-serif;
    font-weight: bold;
    letter-spacing: 1px;
    }


/* FOOTER */
.footer {
  margin-top: 60px;
  padding: 40px;
  background: #222;
  color: white;
  text-align: center;
}

.footer p {
  font-family: "Bebas Neue", sans-serif;
  font-size: 1.5rem;
  letter-spacing: 2px;
  margin-bottom: 20px;
}

.redes {
  display: flex;
  justify-content: center;
  gap: 40px;
  margin-bottom: 24px;
}

.red {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  text-decoration: none;
  color: white;
  transition: transform 0.2s, opacity 0.2s;
}

.red:hover {
  transform: scale(1.1);
  opacity: 0.8;
}

.red img {
  width: 32px;
  height: 32px;
  filter: brightness(0) invert(1);
}

.red span {
  font-size: 0.85rem;
  letter-spacing: 1px;
}

.footer-copy {
  font-size: 0.8rem !important;
  color: #aaa;
  letter-spacing: 1px;
}



